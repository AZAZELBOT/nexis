{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["src/*"],
    },
    "types": ["@rsbuild/core/types", "bun-types", "node"],
  },
  "include": ["src", "rsbuild.config.ts", "tailwind.config.ts"],
}
