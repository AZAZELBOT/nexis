{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@triformine/nexis-sdk": ["../../sdks/ts/src/index.ts"],
      "@triformine/nexis-sdk/*": ["../../sdks/ts/src/*"],
    },
  },
  "include": ["src/**/*.ts"],
}
